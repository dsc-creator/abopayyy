rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Accounts with the `admin: true` custom claim (set server-side via the
    // Firebase Admin SDK — see scripts/grant-admin.js) get full read/write
    // access to every user document, for the admin dashboard.
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // ── Users collection ──────────────────────────────────────────────────
    match /users/{userId} {

      // The user can read their own document; admins can read any document.
      allow read: if isAdmin() || (request.auth != null && request.auth.uid == userId);

      // Allow create only during signup (balance must start at 0)
      allow create: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.balance == 0
        && request.resource.data.uid == userId;

      // Allow updates by the owner, or by an admin (e.g. manual wallet
      // adjustments, suspend/reactivate) from the admin dashboard.
      // Balance can never go negative.
      // A non-admin write can never increase the balance by more than
      // ₦5,000,000 in a single write (protects against a client trying to
      // set an arbitrary balance). Admin writes are trusted server-side.
      allow update: if isAdmin() || (
        request.auth != null
        && request.auth.uid == userId
        && request.resource.data.balance >= 0
        && (request.resource.data.balance - resource.data.balance) <= 5000000
      );

      // No deletes allowed from the client, including admins — deletions
      // should go through a server-side process with an audit trail.
      allow delete: if false;
    }

    // ── Live Chat ────────────────────────────────────────────────────────
    // /chats/{uid} is a summary doc (lastMessage, lastMessageAt, unread
    // flags); /chats/{uid}/messages/{messageId} is the thread itself. Only
    // the owning user and admins can read or write a given thread — nobody
    // else, including other regular users, can see it.
    match /chats/{uid} {
      allow read, write: if isAdmin() || (request.auth != null && request.auth.uid == uid);

      match /messages/{messageId} {
        allow read, write: if isAdmin() || (request.auth != null && request.auth.uid == uid);
      }
    }

    // Block all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
