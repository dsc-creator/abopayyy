rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users collection ──────────────────────────────────────────────────
    match /users/{userId} {

      // Only the authenticated user can read their own document
      allow read: if request.auth != null && request.auth.uid == userId;

      // Allow create only during signup (balance must start at 0)
      allow create: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.balance == 0
        && request.resource.data.uid == userId;

      // Allow updates only by the owner
      // Balance can never go negative
      // Balance can never increase by more than ₦5,000,000 in a single write
      //   (protects against a client trying to set an arbitrary balance)
      allow update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.balance >= 0
        && (request.resource.data.balance - resource.data.balance) <= 5000000;

      // No deletes allowed from the client
      allow delete: if false;
    }

    // Block all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
